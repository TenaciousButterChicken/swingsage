# SwingSage environment configuration
# Copy to .env and fill in. Never commit .env.

# ─── VTrack launch monitor ────────────────────────────────────────────
# Windows production path (verify on first install — UWP package GUID may vary):
#   C:\Users\<you>\AppData\Local\Packages\02ce737d-b4f8-4bbb-92b2-1355681ff1e8_qbntr2denpnae\LocalState\LAON PEOPLE\LPGDLL\ShotData
# Mac dev: leave blank to auto-fall-back to tests/fixtures/vtrack_shots/
VTRACK_SHOTDATA_PATH=

# Force mock VTrack mode even on Windows (useful for offline dev). true|false
SWINGSAGE_USE_MOCK_VTRACK=

# ─── Storage ──────────────────────────────────────────────────────────
# Where the SQLite db and any captured artifacts live. Gitignored.
SWINGSAGE_DATA_DIR=./data/runtime
SWINGSAGE_DB_PATH=./data/runtime/swingsage.db

# ─── Phase 2 model weights (auto-resolved under third_party/; override if moved) ─
# SWINGSAGE_SWINGNET_WEIGHTS=./third_party/golfdb/models/swingnet_1800.pth.tar
# SWINGSAGE_GOLFDB_DIR=./third_party/golfdb
# SWINGSAGE_NLF_WEIGHTS=./third_party/nlf/weights/nlf_l_multi_0.3.2.torchscript

# ─── Coaching LLM (Phase 2) ───────────────────────────────────────────
# LM Studio default HTTP API base + Qwen 3 14B Q5_K_M (load via LM Studio UI).
SWINGSAGE_LLM_MODEL=qwen3-14b
SWINGSAGE_LLM_API_BASE=http://127.0.0.1:1234/v1

# ─── Logging ──────────────────────────────────────────────────────────
SWINGSAGE_LOG_LEVEL=INFO
